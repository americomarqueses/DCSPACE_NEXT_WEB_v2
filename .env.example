# Local development defaults — replace with real secrets for production.
#DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dcspace?schema=public"
NEXTAUTH_SECRET="local-dev-placeholder-change-in-production"
NEXTAUTH_URL="http://localhost:3000"


# Base URL of DCSPACE_NEXT_API (no trailing slash)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# When true, login page shows a dev-only link to list MongoDB user emails (API must run `next dev`)
NEXT_PUBLIC_SHOW_LOGIN_HINTS="true"
